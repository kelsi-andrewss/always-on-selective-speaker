rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData(orgId) {
      return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isMember(orgId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid));
    }

    function getAccessLevel(orgId) {
      return getUserData(orgId).accessLevel;
    }

    function isOwner(orgId) {
      return isMember(orgId) && getAccessLevel(orgId) >= 40;
    }

    function isAdmin(orgId) {
      return isMember(orgId) && getAccessLevel(orgId) >= 30;
    }

    function isSupervisor(orgId) {
      return isMember(orgId) && getAccessLevel(orgId) >= 20;
    }

    function isOfficer(orgId) {
      return isMember(orgId) && getAccessLevel(orgId) >= 10;
    }

    function isValidAccessLevel(value) {
      return value is int && value in [10, 20, 30, 40];
    }

    function getMemberData(orgId, uid) {
      return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(uid)).data;
    }

    // --- Orgs ---
    match /orgs/{orgId} {
      allow read: if isMember(orgId);
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdmin(orgId);

      // --- Members subcollection ---
      match /members/{uid} {
        allow read: if isMember(orgId);
        // Allow first member (creator) to bootstrap themselves as Owner (accessLevel 40)
        // Allow admins to create members with any valid accessLevel
        // Allow self-join with non-admin/non-owner level
        allow create: if isAuthenticated()
          && isValidAccessLevel(request.resource.data.accessLevel)
          && (isAdmin(orgId)
            || (uid == request.auth.uid && request.resource.data.accessLevel == 40
              && get(/databases/$(database)/documents/orgs/$(orgId)).data.createdBy == request.auth.uid)
            || (uid == request.auth.uid && request.resource.data.accessLevel <= 20));
        allow update: if isAdmin(orgId)
          && isValidAccessLevel(request.resource.data.accessLevel);
        // Delete: admins can delete, but non-owners cannot delete owners
        allow delete: if isAdmin(orgId)
          && (getMemberData(orgId, uid).accessLevel < 40 || isOwner(orgId));
      }

      // --- Invites subcollection ---
      match /invites/{code} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin(orgId);
      }
    }

    // --- Transcripts ---
    match /transcripts/{transcriptId} {
      allow read: if isAuthenticated()
        && resource.data.orgId is string
        && (
          isAdmin(resource.data.orgId)
          || (isOfficer(resource.data.orgId) && resource.data.recordedBy == request.auth.uid)
          || (isSupervisor(resource.data.orgId) && resource.data.recordedBy in getUserData(resource.data.orgId).assignedOfficers)
        );

      allow create: if isAuthenticated()
        && request.resource.data.orgId is string
        && isMember(request.resource.data.orgId)
        && request.resource.data.recordedBy == request.auth.uid;

      allow update: if isAuthenticated()
        && resource.data.orgId is string
        && resource.data.recordedBy == request.auth.uid
        && isMember(resource.data.orgId)
        && request.resource.data.orgId == resource.data.orgId
        && request.resource.data.recordedBy == resource.data.recordedBy;

      allow delete: if isAuthenticated()
        && resource.data.orgId is string
        && isAdmin(resource.data.orgId);
    }
  }
}
