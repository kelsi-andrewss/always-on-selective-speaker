rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData(orgId) {
      return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isMember(orgId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid));
    }

    function isAdmin(orgId) {
      return isMember(orgId) && getUserData(orgId).accessLevel >= 30;
    }

    // --- Orgs ---
    match /orgs/{orgId} {
      allow create: if isAuthenticated();
      allow read: if isMember(orgId) || resource.data.visibility == "public";
      allow update, delete: if isAdmin(orgId);

      // --- Members ---
      match /members/{uid} {
        // Self-read always (login resolution), org members can read each other.
        // Public orgs allow anyone to see member list.
        allow read: if isAuthenticated() && (
            uid == request.auth.uid || 
            isMember(orgId) || 
            get(/databases/$(database)/documents/orgs/$(orgId)).data.visibility == "public"
        );
        // You can create your own member doc. Admins can create anyone's.
        allow create: if isAuthenticated() && (uid == request.auth.uid || isAdmin(orgId));
        // Only admins can modify or remove
        allow update, delete: if isAdmin(orgId);
      }

      // --- Invites ---
      match /invites/{code} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin(orgId);
      }

      // --- Transcripts (per-org) ---
      match /transcripts/{transcriptId} {
        allow read: if isMember(orgId) || get(/databases/$(database)/documents/orgs/$(orgId)).data.visibility == "public";

        allow create: if isAuthenticated()
          && isMember(orgId)
          && request.resource.data.recordedBy == request.auth.uid;

        allow update: if isAuthenticated()
          && isMember(orgId)
          && resource.data.recordedBy == request.auth.uid;

        allow delete: if isAdmin(orgId);
      }
    }

    // --- CollectionGroup: members (for login resolution + org listing) ---
    match /{path=**}/members/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
    }

    // --- Users (org membership tracking) ---
    match /users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // --- Transcripts ---
    match /transcripts/{transcriptId} {
      allow read: if isAuthenticated()
        && resource.data.orgId is string
        && (isMember(resource.data.orgId) || get(/databases/$(database)/documents/orgs/$(resource.data.orgId)).data.visibility == "public");

      allow create: if isAuthenticated()
        && request.resource.data.orgId is string
        && isMember(request.resource.data.orgId)
        && request.resource.data.recordedBy == request.auth.uid;

      allow update: if isAuthenticated()
        && resource.data.orgId is string
        && isMember(resource.data.orgId)
        && resource.data.recordedBy == request.auth.uid;

      allow delete: if isAuthenticated()
        && resource.data.orgId is string
        && isAdmin(resource.data.orgId);
    }
  }
}
